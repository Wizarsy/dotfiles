  { "key": "up",                    "command": "selectPrevCodeAction",
                                       "when": "codeActionMenuVisible" },
  { "key": "escape",                "command": "diffEditor.exitCompareMove",
                                       "when": "comparingMovedCode" }
  ]
  
  
